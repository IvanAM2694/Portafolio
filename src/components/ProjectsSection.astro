---
import { userData } from "../data/userData";
---

<section id="projects" class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-900/50">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
      <span class="bg-gradient-to-r from-blue-400 to-purple-600 bg-clip-text text-transparent">
        Proyectos Destacados
      </span>
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {userData.projects.map((project, index) => (
        <div 
          class="bg-gray-800/50 backdrop-blur-sm rounded-lg p-6 border border-gray-700 hover:border-blue-500 transition-all transform hover:scale-[1.02] shadow-lg hover:shadow-blue-500/20 group"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-semibold text-white group-hover:text-blue-400 transition-colors">
              {project.name}
            </h3>
            {project.language && (
              <span class="px-2 py-1 bg-gray-700 text-gray-300 rounded text-xs">
                {project.language}
              </span>
            )}
          </div>
          <p class="text-gray-300 mb-4">{project.description}</p>
          <div class="flex flex-wrap gap-2 mb-4">
            {project.technologies.map((tech) => (
              <span class="px-2 py-1 bg-blue-500/20 text-blue-300 rounded text-xs border border-blue-500/30">
                {tech}
              </span>
            ))}
          </div>
          <div class="flex gap-4">
            {project.github && (
              <a 
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-400 hover:text-blue-300 transition-colors flex items-center gap-2"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                Código
              </a>
            )}
            <a 
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-400 hover:text-blue-300 transition-colors flex items-center gap-2"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Ver Proyecto
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

