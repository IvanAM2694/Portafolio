---
import { userData } from "../data/userData";
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-md border-b border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <a href="#home" class="text-xl font-bold text-white hover:text-blue-400 transition-colors">
        {userData.name}
      </a>
      <div class="hidden md:flex space-x-8">
        <a href="#home" class="text-gray-300 hover:text-white transition-colors">Inicio</a>
        <a href="#experience" class="text-gray-300 hover:text-white transition-colors">Experiencia</a>
        <a href="#technologies" class="text-gray-300 hover:text-white transition-colors">Tecnologías</a>
        <a href="#projects" class="text-gray-300 hover:text-white transition-colors">Proyectos</a>
        <a href="#contact" class="text-gray-300 hover:text-white transition-colors">Contacto</a>
      </div>
      <div class="md:hidden">
        <button id="mobile-menu-button" class="text-gray-300 hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden bg-gray-900 border-t border-gray-800">
    <div class="px-4 py-4 space-y-4">
      <a href="#home" class="block text-gray-300 hover:text-white transition-colors">Inicio</a>
      <a href="#experience" class="block text-gray-300 hover:text-white transition-colors">Experiencia</a>
      <a href="#technologies" class="block text-gray-300 hover:text-white transition-colors">Tecnologías</a>
      <a href="#projects" class="block text-gray-300 hover:text-white transition-colors">Proyectos</a>
      <a href="#contact" class="block text-gray-300 hover:text-white transition-colors">Contacto</a>
    </div>
  </div>
</nav>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
