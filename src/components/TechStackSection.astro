---
import { userData } from "../data/userData";
import TechIcon from "./TechIcon.astro";
---

<section id="technologies" class="scroll-mt-16 py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
      <span class="text-gradient-heading">Tecnologías</span>
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 sm:gap-6">
      {userData.technologies.map((tech, index) => (
        <div
          class="card-surface p-4 sm:p-6 transform hover:scale-105 text-center group"
          style={`animation-delay: ${index * 0.05}s`}
        >
          <div class="mb-2 sm:mb-3 group-hover:scale-110 transition-transform flex justify-center">
            <TechIcon name={tech} />
          </div>
          <h3 class="text-white font-semibold text-sm sm:text-base leading-tight">{tech}</h3>        </div>
      ))}
    </div>
  </div>
</section>
