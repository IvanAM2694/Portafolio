---
import { userData } from "../data/userData";
import SocialLinks from "./SocialLinks.astro";
---

<footer class="border-t border-ivam-border py-8 px-4 sm:px-6 lg:px-8 bg-ivam-bg/60 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-center md:text-left">
        <p class="text-white text-sm font-semibold">{userData.brandName}</p>
        <p class="text-ivam-muted text-sm">
          © {new Date().getFullYear()} {userData.name}. Todos los derechos reservados.
        </p>
      </div>
      <SocialLinks />
    </div>
  </div>
</footer>
